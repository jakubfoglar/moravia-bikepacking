<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="22sp"
            android:text="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:text="Bikepacking · Břeclav → Otrokovice" />

        <!-- Update card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_bg"
            android:padding="16dp">
            <TextView
                android:id="@+id/version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#14141A"
                android:textSize="14sp"
                android:text="Build 1" />
            <Button
                android:id="@+id/btn_update"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_update_bg"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:text="Check for update" />
            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#26262B"
                android:textSize="13sp"
                android:text="" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="Setup" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:text="Add “POI Catalog”, “Train Catcher” and “Day Overview” to ride pages, and “Next POI” to your map page. Works offline; update over WiFi." />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="Trip day" />
        <TextView
            android:id="@+id/day_effective"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:text="Currently: Day 1" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">
            <Button android:id="@+id/day_auto" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Auto" />
            <Button android:id="@+id/day_1" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Day 1" />
            <Button android:id="@+id/day_2" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Day 2" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="Features" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5A5A60"
            android:textSize="12sp"
            android:text="Turn parts off if anything misbehaves on the road. Radar/map take effect on the next start." />
        <Switch
            android:id="@+id/sw_radar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Radar Traffic (needs a rear radar)" />
        <Switch
            android:id="@+id/sw_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Map overlay: train-deadline pin" />
        <Switch
            android:id="@+id/sw_scenic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Minimap: scenic area (Day 1)" />

        <!-- Follow website -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="@string/posting_head" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#5A5A60"
            android:textSize="12sp"
            android:text="Ride events post themselves over the phone link — no WiFi needed. Paste the secret once." />
        <Switch
            android:id="@+id/sw_posting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/posting_flag" />
        <EditText
            android:id="@+id/ed_secret"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/posting_secret_hint"
            android:inputType="textVisiblePassword"
            android:textSize="13sp"
            android:autofillHints="password" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <Button android:id="@+id/btn_secret" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/posting_save" />
            <Button android:id="@+id/btn_testpost" style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/posting_test" />
        </LinearLayout>
        <Button
            android:id="@+id/btn_sketch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/btn_update_bg"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:text="@string/posting_sketch" />
        <TextView
            android:id="@+id/post_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#26262B"
            android:textSize="13sp"
            android:text="" />

        <!-- Diagnostics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#14141A"
                android:textStyle="bold"
                android:textSize="15sp"
                android:text="Diagnostics" />
            <Button
                android:id="@+id/btn_copy"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6A1B9A"
                android:textStyle="bold"
                android:textSize="13sp"
                android:text="Copy" />
            <Button
                android:id="@+id/btn_share"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6A1B9A"
                android:textStyle="bold"
                android:textSize="13sp"
                android:text="Share" />
        </LinearLayout>

        <TextView
            android:id="@+id/logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/log_bg"
            android:padding="12dp"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="#444444"
            android:text="(no logs yet)" />

        <Button
            android:id="@+id/btn_refresh"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:text="Refresh" />
    </LinearLayout>
</ScrollView>
