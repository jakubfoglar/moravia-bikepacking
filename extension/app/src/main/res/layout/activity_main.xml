<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="22sp"
            android:text="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:text="Bikepacking · Břeclav → Otrokovice" />

        <!-- Update card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_bg"
            android:padding="16dp">
            <TextView
                android:id="@+id/version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#14141A"
                android:textSize="14sp"
                android:text="Build 1" />
            <Button
                android:id="@+id/btn_update"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_update_bg"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:text="Check for update" />
            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#26262B"
                android:textSize="13sp"
                android:text="" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="#14141A"
            android:textStyle="bold"
            android:textSize="15sp"
            android:text="Setup" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:text="Add “POI Catalog” to a full-size ride page, and “Next POI” to your map page. Works offline; update over WiFi." />

        <!-- Diagnostics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#14141A"
                android:textStyle="bold"
                android:textSize="15sp"
                android:text="Diagnostics" />
            <Button
                android:id="@+id/btn_copy"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6A1B9A"
                android:textStyle="bold"
                android:textSize="13sp"
                android:text="Copy" />
            <Button
                android:id="@+id/btn_share"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6A1B9A"
                android:textStyle="bold"
                android:textSize="13sp"
                android:text="Share" />
        </LinearLayout>

        <TextView
            android:id="@+id/logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/log_bg"
            android:padding="12dp"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="#444444"
            android:text="(no logs yet)" />

        <Button
            android:id="@+id/btn_refresh"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#5A5A60"
            android:textSize="13sp"
            android:text="Refresh" />
    </LinearLayout>
</ScrollView>
