<?xml version="1.0" encoding="utf-8"?>
<!-- FULL tier (field height ≥ 420 px): the rich catalog card.
     RemoteViews-safe widgets only; dividers are 1dp TextViews (a bare <View> breaks inflation). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/k_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER: photo + category/name block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp">
                <ImageView
                    android:id="@+id/photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null" />
                <TextView
                    android:id="@+id/tile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="44sp"
                    android:background="#2E7D32"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/k_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:text="PAMÁTKA" />
                <TextView
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textColor="@color/k_ink"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:text="Name" />
                <TextView
                    android:id="@+id/sub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/k_muted"
                    android:textSize="13sp"
                    android:text="Lednice · 1. den" />
            </LinearLayout>
        </LinearLayout>

        <!-- DISTANCE band (located) -->
        <LinearLayout
            android:id="@+id/dist_band"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/dist_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/k_ink"
                android:textSize="34sp"
                android:textStyle="bold"
                android:text="3,4" />
            <TextView
                android:id="@+id/dist_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="5dp"
                android:layout_gravity="bottom"
                android:textColor="@color/k_muted"
                android:textSize="15sp"
                android:text="km" />
        </LinearLayout>

        <!-- GPS band (not located) -->
        <LinearLayout
            android:id="@+id/gps_band"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">
            <ProgressBar
                android:id="@+id/gps_spinner"
                android:layout_width="16dp"
                android:layout_height="16dp" />
            <TextView
                android:id="@+id/gps_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/k_muted"
                android:textSize="15sp"
                android:text="@string/fld_gps" />
        </LinearLayout>

        <TextView
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:text=""
            android:background="@color/k_divider" />

        <TextView
            android:id="@+id/hook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="3"
            android:ellipsize="end"
            android:textColor="@color/k_ink"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp"
            android:text="Proč tu zastavit" />

        <TextView
            android:id="@+id/more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/k_muted_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="@string/fld_full_story" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="" />

        <!-- NAV: prev bottom-left, next bottom-right — mirrors the Karoo's physical buttons. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/btn_prev"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_ghost"
                android:textColor="@color/k_ink"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:paddingLeft="26dp"
                android:paddingRight="26dp"
                android:paddingTop="10dp"
                android:paddingBottom="12dp"
                android:text="‹" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/cnt_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/k_muted"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:text="@string/fld_order_ahead" />
                <TextView
                    android:id="@+id/cnt_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/k_ink"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:text="5 / 79" />
            </LinearLayout>
            <TextView
                android:id="@+id/btn_next"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_action"
                android:textColor="@color/k_ink"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:paddingLeft="26dp"
                android:paddingRight="26dp"
                android:paddingTop="10dp"
                android:paddingBottom="12dp"
                android:text="›" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
