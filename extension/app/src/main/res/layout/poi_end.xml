<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/k_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="40sp"
        android:text="🏁" />
    <TextView
        android:id="@+id/end_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/k_ink"
        android:textStyle="bold"
        android:textSize="18sp"
        android:text="To je všech 79 míst" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/k_muted"
        android:textSize="14sp"
        android:text="@string/fld_end_sub" />
    <TextView
        android:id="@+id/btn_prev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/pill_ghost"
        android:textColor="@color/k_ink"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingLeft="22dp"
        android:paddingRight="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="@string/fld_end_back" />
</LinearLayout>
