<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFFFFF"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="40sp"
        android:text="🏁" />
    <TextView
        android:id="@+id/end_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#14141A"
        android:textStyle="bold"
        android:textSize="18sp"
        android:text="That's all 79 POIs" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="#5A5A60"
        android:textSize="14sp"
        android:text="Everything's behind you — nice riding." />
    <TextView
        android:id="@+id/btn_prev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/btn_ghost"
        android:textColor="#14141A"
        android:textStyle="bold"
        android:textSize="15sp"
        android:paddingLeft="22dp"
        android:paddingRight="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="‹ Back to first" />
</LinearLayout>
