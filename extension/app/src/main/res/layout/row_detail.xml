<?xml version="1.0" encoding="utf-8"?>
<!-- One practical row in the POI detail: icon · uppercase grey label · dark value (Karoo row idiom). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingLeft="18dp"
    android:paddingRight="18dp"
    android:paddingTop="13dp"
    android:paddingBottom="13dp">

    <TextView
        android:id="@+id/row_icon"
        android:layout_width="52dp"
        android:layout_height="wrap_content"
        android:paddingLeft="6dp"
        android:textSize="21sp"
        android:text="🕒" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/row_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/k_muted"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:text="OTEVÍRACÍ DOBA" />
        <TextView
            android:id="@+id/row_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/k_ink"
            android:textSize="19sp"
            android:textStyle="bold"
            android:text="Otevřeno do 17:00" />
        <TextView
            android:id="@+id/row_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/k_muted"
            android:textSize="13sp"
            android:visibility="gone"
            android:text="" />
    </LinearLayout>
</LinearLayout>
