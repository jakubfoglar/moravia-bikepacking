<?xml version="1.0" encoding="utf-8"?>
<!-- App home = the catalog itself (Karoo OS look). Settings live behind the gear, top-right. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/k_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="18dp"
        android:paddingRight="14dp">
        <TextView
            android:id="@+id/c_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/k_ink"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:text="MÍSTA NA TRASE" />
        <TextView
            android:id="@+id/c_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="16sp"
            android:contentDescription="Settings"
            android:text="⚙" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/k_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">
        <LinearLayout
            android:id="@+id/c_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
