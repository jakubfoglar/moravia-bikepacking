<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sketch_title"
        android:textColor="#14141A"
        android:textSize="11sp"
        android:textStyle="bold" />

    <!-- The pad takes all the room left over after the title, status and buttons. -->
    <cz.tripcompanion.SketchView
        android:id="@+id/pad"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:background="#F5F6F7" />

    <TextView
        android:id="@+id/sk_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#5A5A60"
        android:textSize="10sp"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/sk_undo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:text="@string/sketch_undo" />

        <Button
            android:id="@+id/sk_clear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="11sp"
            android:text="@string/sketch_clear" />

        <Button
            android:id="@+id/sk_close"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textSize="11sp"
            android:text="@string/sketch_close" />

        <Button
            android:id="@+id/sk_send"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.3"
            android:layout_marginStart="6dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:text="@string/sketch_send" />
    </LinearLayout>
</LinearLayout>
