<?xml version="1.0" encoding="utf-8"?>
<!-- POI detail, styled after the Karoo OS (480×800, white, Open Sans, uppercase grey labels,
     hairline dividers, pill actions bottom-left/right where the physical buttons sit). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/k_bg">

    <!-- Top bar: category icon + uppercase title, position counter right. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="53dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">
        <TextView
            android:id="@+id/d_cat_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:text="🏰" />
        <TextView
            android:id="@+id/d_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/k_ink"
            android:textSize="19sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:text="PAMÁTKA" />
        <TextView
            android:id="@+id/d_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/k_muted"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="3 / 12" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/k_divider" />

    <ScrollView
        android:id="@+id/d_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/d_photo"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="16dp">

                <TextView
                    android:id="@+id/d_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/k_ink"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:text="Zámek Lednice" />

                <TextView
                    android:id="@+id/d_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/k_muted"
                    android:textSize="15sp"
                    android:text="Lednice · 1. den · odbočka 1,6 km" />

                <!-- EAT/DRINK: the big live hours line ("Otevřeno do 20:00"). -->
                <TextView
                    android:id="@+id/d_hours_big"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/k_green"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:text="Otevřeno do 20:00" />

                <!-- SIGHT: the story. EAT/DRINK: an optional 1-line note. -->
                <TextView
                    android:id="@+id/d_blurb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/k_ink"
                    android:textSize="19sp"
                    android:lineSpacingExtra="7dp"
                    android:text="" />
            </LinearLayout>

            <View
                android:id="@+id/d_rows_top_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/k_divider_soft" />

            <!-- Practical rows (hours, admission, effort, cuisine, payment, phone, detour)
                 are added here in code; each hides when its data is absent. -->
            <LinearLayout
                android:id="@+id/d_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="14dp"
                android:paddingBottom="16dp">
                <TextView
                    android:id="@+id/d_maps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/pill_ghost"
                    android:gravity="center"
                    android:textColor="@color/k_ink"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:text="@string/det_maps_google" />
                <TextView
                    android:id="@+id/d_mapy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/pill_ghost"
                    android:gravity="center"
                    android:textColor="@color/k_ink"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:text="@string/det_maps_mapy" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/k_divider" />

    <!-- Bottom bar: back bottom-left, browse actions bottom-right — like the hardware buttons. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">
        <TextView
            android:id="@+id/d_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_ghost"
            android:textColor="@color/k_ink"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingLeft="22dp"
            android:paddingRight="22dp"
            android:paddingTop="13dp"
            android:paddingBottom="14dp"
            android:text="@string/det_back" />
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/d_prev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_ghost"
            android:textColor="@color/k_ink"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="10dp"
            android:paddingBottom="13dp"
            android:text="@string/det_prev" />
        <TextView
            android:id="@+id/d_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/pill_action"
            android:textColor="@color/k_ink"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="13dp"
            android:paddingBottom="14dp"
            android:text="@string/det_next" />
    </LinearLayout>
</LinearLayout>
