<?xml version="1.0" encoding="utf-8"?>
<!-- POI detail, styled after the Karoo OS (480×800 @ density 2.0 → 1sp ≈ 2px; white, system
     font, uppercase grey labels, hairline dividers, pill actions bottom-left/right where the
     physical buttons sit). Sizes are calibrated against the native Karoo UI (~22–26px titles),
     so they look small in a phone preview but right on-device. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/k_bg">

    <!-- Top bar: category icon + uppercase title, position counter right. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">
        <TextView
            android:id="@+id/d_cat_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:text="🏰" />
        <TextView
            android:id="@+id/d_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/k_ink"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:text="PAMÁTKA" />
        <TextView
            android:id="@+id/d_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/k_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="3 / 12" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/k_divider" />

    <ScrollView
        android:id="@+id/d_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/d_photo"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:paddingTop="12dp">

                <TextView
                    android:id="@+id/d_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/k_ink"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:text="Zámek Lednice" />

                <TextView
                    android:id="@+id/d_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/k_muted"
                    android:textSize="10sp"
                    android:text="Lednice · 1. den · odbočka 1,6 km" />

                <!-- EAT/DRINK: the big live hours line ("Otevřeno do 20:00"). -->
                <TextView
                    android:id="@+id/d_hours_big"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/k_green"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:text="Otevřeno do 20:00" />

                <!-- SIGHT: the story. EAT/DRINK: an optional 1-line note. -->
                <TextView
                    android:id="@+id/d_blurb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/k_ink"
                    android:textSize="10sp"
                    android:lineSpacingExtra="3dp"
                    android:text="" />
            </LinearLayout>

            <View
                android:id="@+id/d_rows_top_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="@color/k_divider_soft" />

            <!-- Practical rows (hours, admission, effort, cuisine, payment, phone, detour)
                 are added here in code; each hides when its data is absent. -->
            <LinearLayout
                android:id="@+id/d_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/k_divider" />

    <!-- Bottom bar: back bottom-left, browse actions bottom-right — like the hardware buttons. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">
        <TextView
            android:id="@+id/d_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_ghost"
            android:textColor="@color/k_ink"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="11dp"
            android:text="@string/det_back" />
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/d_prev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill_ghost"
            android:textColor="@color/k_ink"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingLeft="22dp"
            android:paddingRight="22dp"
            android:paddingTop="8dp"
            android:paddingBottom="10dp"
            android:text="@string/det_prev" />
        <TextView
            android:id="@+id/d_next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/pill_action"
            android:textColor="@color/k_ink"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingLeft="22dp"
            android:paddingRight="22dp"
            android:paddingTop="10dp"
            android:paddingBottom="11dp"
            android:text="@string/det_next" />
    </LinearLayout>
</LinearLayout>
