<?xml version="1.0" encoding="utf-8"?>
<!-- Open Sans = the Karoo system face. Bundled so Activities render native even though
     the app process doesn't inherit the OS font. (RemoteViews text can't use it — fields
     rely on the system default, which on the Karoo is Open Sans anyway.)
     app: attributes are the pre-API-28 (AppCompat) path; android: the platform one. -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        android:font="@font/open_sans_regular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/open_sans_regular"
        app:fontStyle="normal"
        app:fontWeight="400" />
    <font
        android:font="@font/open_sans_bold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/open_sans_bold"
        app:fontStyle="normal"
        app:fontWeight="700" />
</font-family>
