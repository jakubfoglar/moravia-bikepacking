<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- System-native font only: the Karoo's default UI font is already Open Sans,
         so we bundle nothing and text keeps the native face. -->
    <style name="Theme.TripCompanion" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- POI detail: always the white Karoo ride-UI look, never inverted by DayNight. -->
    <style name="Theme.TripCompanion.PoiDetail" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/k_bg</item>
    </style>
</resources>
